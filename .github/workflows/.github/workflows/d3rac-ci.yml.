name: D3R·AC CI

# Comprehensive CI workflow for D3R·AC.
#
# v3 fix notes:
# 1. Removed the "changes" job and dorny/paths-filter entirely. It was
#    failing because paths-filter needs enough git history to diff
#    against, and the shallow default checkout didn't provide that —
#    which cascaded into every downstream job being skipped. Each job
#    below now runs on every trigger, but internally checks whether its
#    target files actually exist before doing real work (added in v2),
#    so this is simpler AND more reliable.
# 2. Secret scanning now fetches whatever gitleaks' actual latest
#    release is via the GitHub API, instead of a hardcoded version
#    string — removes any risk of a stale/incorrect pinned version.

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main, develop ]
  workflow_dispatch: {}

jobs:

  # ---------------------------------------------------------------
  # 1. Smart contract compile check (TRON / TVM, Solidity)
  # ---------------------------------------------------------------
  contracts-tron:
    name: Compile TRON Contracts
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Check contracts directory exists
        id: check
        run: |
          if [ -d "contracts/tron" ] && [ -n "$(find contracts/tron -name '*.sol' 2>/dev/null)" ]; then
            echo "exists=true" >> "$GITHUB_OUTPUT"
          else
            echo "exists=false" >> "$GITHUB_OUTPUT"
            echo "::notice::contracts/tron has no .sol files yet — skipping compile step."
          fi

      - name: Set up Node.js
        if: steps.check.outputs.exists == 'true'
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install TronBox
        if: steps.check.outputs.exists == 'true'
        run: npm install -g tronbox

      - name: Compile TRON contracts
        if: steps.check.outputs.exists == 'true'
        working-directory: contracts/tron
        run: tronbox compile

      - name: Upload compiled artifacts
        if: steps.check.outputs.exists == 'true'
        uses: actions/upload-artifact@v4
        with:
          name: tron-build-artifacts
          path: contracts/tron/build/

  # ---------------------------------------------------------------
  # 2. Solidity static analysis / linting (security hygiene)
  # ---------------------------------------------------------------
  contracts-lint:
    name: Lint & Static Analysis (Solidity)
    needs: contracts-tron
    if: always() && needs.contracts-tron.result == 'success'
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Check contracts directory exists
        id: check
        run: |
          if [ -d "contracts/tron" ] && [ -n "$(find contracts/tron -name '*.sol' 2>/dev/null)" ]; then
            echo "exists=true" >> "$GITHUB_OUTPUT"
          else
            echo "exists=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Set up Node.js
        if: steps.check.outputs.exists == 'true'
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install solhint
        if: steps.check.outputs.exists == 'true'
        run: npm install -g solhint

      - name: Run solhint
        if: steps.check.outputs.exists == 'true'
        working-directory: contracts/tron
        run: solhint '**/*.sol' || true

  # ---------------------------------------------------------------
  # 3. Frontend build & test (community access layer)
  # ---------------------------------------------------------------
  frontend:
    name: Frontend Build & Test
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Check frontend directory exists
        id: check
        run: |
          if [ -f "frontend/package.json" ]; then
            echo "exists=true" >> "$GITHUB_OUTPUT"
          else
            echo "exists=false" >> "$GITHUB_OUTPUT"
            echo "::notice::frontend/package.json not found yet — skipping frontend build."
          fi

      - name: Set up Node.js
        if: steps.check.outputs.exists == 'true'
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: frontend/package-lock.json

      - name: Install dependencies
        if: steps.check.outputs.exists == 'true'
        working-directory: frontend
        run: npm ci

      - name: Run lint
        if: steps.check.outputs.exists == 'true'
        working-directory: frontend
        run: npm run lint --if-present

      - name: Run tests
        if: steps.check.outputs.exists == 'true'
        working-directory: frontend
        run: npm test --if-present

      - name: Build production bundle
        if: steps.check.outputs.exists == 'true'
        working-directory: frontend
        run: npm run build

      - name: Upload build artifacts
        if: steps.check.outputs.exists == 'true'
        uses: actions/upload-artifact@v4
        with:
          name: frontend-build
          path: frontend/dist/

  # ---------------------------------------------------------------
  # 4. Data pipeline checks (risk-scoring R(c,t) implementation)
  # ---------------------------------------------------------------
  data-pipeline:
    name: Data Pipeline Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Check data-pipeline directory exists
        id: check
        run: |
          if [ -d "data-pipeline" ] && [ -n "$(find data-pipeline -name '*.py' 2>/dev/null)" ]; then
            echo "exists=true" >> "$GITHUB_OUTPUT"
          else
            echo "exists=false" >> "$GITHUB_OUTPUT"
            echo "::notice::data-pipeline has no Python files yet — skipping."
          fi

      - name: Set up Python
        if: steps.check.outputs.exists == 'true'
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'
          cache-dependency-path: data-pipeline/requirements.txt

      - name: Install dependencies
        if: steps.check.outputs.exists == 'true'
        working-directory: data-pipeline
        run: |
          python -m pip install --upgrade pip
          if [ -f requirements.txt ]; then pip install -r requirements.txt; fi

      - name: Run tests
        if: steps.check.outputs.exists == 'true'
        working-directory: data-pipeline
        run: |
          if [ -d tests ]; then pytest tests/; else echo "No tests directory yet — skipping."; fi

  # ---------------------------------------------------------------
  # 5. Secret scanning — raw Gitleaks CLI, dynamically fetches latest
  # ---------------------------------------------------------------
  secret-scan:
    name: Secret Scanning
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Download and run Gitleaks CLI (latest release)
        run: |
          set -e
          LATEST_TAG=$(curl -sSL https://api.github.com/repos/gitleaks/gitleaks/releases/latest | grep '"tag_name":' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/')
          VERSION=${LATEST_TAG#v}
          echo "Fetching gitleaks ${LATEST_TAG}"
          curl -sSL "https://github.com/gitleaks/gitleaks/releases/download/${LATEST_TAG}/gitleaks_${VERSION}_linux_x64.tar.gz" -o gitleaks.tar.gz
          tar -xzf gitleaks.tar.gz gitleaks
          chmod +x gitleaks
          ./gitleaks detect --source . --verbose --redact
        # Runs the open-source CLI directly — free regardless of repo
        # visibility, no GitHub Marketplace Action license needed.
        # Always fetches whatever is currently tagged "latest" so this
        # never goes stale from a hardcoded version number.

  # ---------------------------------------------------------------
  # 6. Summary job — single required status check for branch protection
  # ---------------------------------------------------------------
  ci-summary:
    name: CI Summary
    runs-on: ubuntu-latest
    needs: [ contracts-tron, contracts-lint, frontend, data-pipeline, secret-scan ]
    if: always()
    steps:
      - name: Report status
        run: |
          echo "Contracts (TRON):   ${{ needs.contracts-tron.result }}"
          echo "Contracts lint:     ${{ needs.contracts-lint.result }}"
          echo "Frontend:           ${{ needs.frontend.result }}"
          echo "Data pipeline:      ${{ needs.data-pipeline.result }}"
          echo "Secret scan:        ${{ needs.secret-scan.result }}"

          if [[ "${{ needs.contracts-tron.result }}" == "failure" ]] || \
             [[ "${{ needs.contracts-lint.result }}" == "failure" ]] || \
             [[ "${{ needs.frontend.result }}" == "failure" ]] || \
             [[ "${{ needs.data-pipeline.result }}" == "failure" ]] || \
             [[ "${{ needs.secret-scan.result }}" == "failure" ]]; then
            echo "One or more jobs failed."
            exit 1
          fi